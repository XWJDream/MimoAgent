{
  "name": "mimo-desktop",
  "version": "0.2.0",
  "type": "module",
  "description": "MimoAgent Desktop - AI coding agent powered by mimo-v2.5-pro",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "start": "npm run build && electron .",
    "start:dev": "tsx scripts/dev.ts",
    "build": "npm run build:engine && tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && vite build",
    "build:engine": "npm --prefix engine run build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "preview": "vite preview",
    "electron:dev": "tsx scripts/dev.ts",
    "electron:build": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win nsis",
    "package:dir": "npm run build && electron-builder --dir",
    "package:zip": "npm run package:dir && powershell -ExecutionPolicy Bypass -File scripts/package-zip.ps1",
    "lint": "eslint src/"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "clsx": "^2.0.0",
    "commander": "^14.0.3",
    "diff": "^9.0.0",
    "dockerode": "^5.0.0",
    "dompurify": "^3.4.7",
    "dotenv": "^17.4.2",
    "glob": "^13.0.6",
    "ink": "^7.0.4",
    "ink-markdown": "^1.0.4",
    "ink-text-input": "^6.0.0",
    "lucide-react": "^1.16.0",
    "marked": "^15.0.0",
    "marked-terminal": "^7.3.0",
    "openai": "^4.78.0",
    "ora": "^9.4.0",
    "p-limit": "^7.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^4.1.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
