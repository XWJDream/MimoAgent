{
  "name": "mimo-desktop",
  "version": "0.3.0",
  "type": "module",
  "author": "MimoAgent Contributors",
  "description": "MimoAgent Desktop - AI coding agent powered by mimo-v2.5-pro",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "start": "npm run build && electron .",
    "start:dev": "tsx scripts/dev.ts",
    "clean": "node scripts/clean-build.mjs",
    "build": "npm run clean && npm run build:engine && tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && node scripts/write-preload-package.mjs && vite build",
    "build:engine": "npm --prefix engine run build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "preview": "vite preview",
    "electron:dev": "tsx scripts/dev.ts",
    "electron:build": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win nsis",
    "package:dir": "npm run build && electron-builder --dir",
    "package:zip": "npm run package:dir && powershell -ExecutionPolicy Bypass -File scripts/package-zip.ps1",
    "lint": "eslint \"src/**/*.{ts,tsx}\" && npm --prefix engine run lint",
    "typecheck": "npm run typecheck:engine && npm run typecheck:main && npm run typecheck:preload && npm run typecheck:renderer",
    "typecheck:engine": "tsc -p engine/tsconfig.json --noEmit",
    "typecheck:main": "tsc -p tsconfig.main.json --noEmit",
    "typecheck:preload": "tsc -p tsconfig.preload.json --noEmit",
    "typecheck:renderer": "tsc -p tsconfig.json --noEmit",
    "test:engine": "vitest run --config vitest.engine.config.ts",
    "test:main": "vitest run --config vitest.main.config.ts",
    "test:renderer": "vitest run --config vitest.renderer.config.ts",
    "test:live": "vitest run --config vitest.live.config.ts",
    "test": "npm run test:engine && npm run test:main && npm run test:renderer"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.6.2",
    "clsx": "^2.0.0",
    "commander": "^14.0.3",
    "diff": "^9.0.0",
    "dockerode": "^5.0.0",
    "dompurify": "^3.4.7",
    "dotenv": "^17.4.2",
    "glob": "^13.0.6",
    "ink": "^7.0.4",
    "ink-markdown": "^1.0.4",
    "ink-text-input": "^6.0.0",
    "lucide-react": "^1.16.0",
    "marked": "^15.0.0",
    "marked-terminal": "^7.3.0",
    "openai": "^4.78.0",
    "ora": "^9.4.0",
    "p-limit": "^7.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^4.1.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22"
  },
  "allowScripts": {
    "electron@33.4.11": true,
    "esbuild@0.28.0": true,
    "esbuild@0.25.12": true,
    "fsevents@2.3.3": true,
    "protobufjs@7.6.1": true,
    "ssh2@1.17.0": true
  }
}
